local function settings(self)
	texture = "settings"
	gui.set_enabled(gui.get_node("Os"), false)
	for i = 1, 8 do
		gui.set_enabled(gui.get_node("InterBg" .. i), false)
		gui.set_scale(gui.get_node("InterBg" .. i), vmath.vector3(0.65, 0.65, 1))
	end
	gui.set_enabled(gui.get_node("Settings"), false)
	gui.set_enabled(gui.get_node("PublicBg"), false)
	gui.set_enabled(gui.get_node("Support"), false)
	gui.set_enabled(gui.get_node("ExitBg"), false)
