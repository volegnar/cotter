	gui.set_enabled(gui.get_node("StartBg"), false)
	gui.set_enabled(gui.get_node("Version"), false)
	gui.set_enabled(gui.get_node("TopFrame"), false)
	gui.set_enabled(gui.get_node("ResultsBanner"), false)
	gui.set_color(gui.get_node("Keyboard"), vmath.vector4(1, 1, 1, 1))
	refresh_interfaces(self)
	gui.set_text(gui.get_node("version"), self.sysname .. " " .. self.sysversion)
	gui.set_text(gui.get_node("osversion"), "Cotter " .. self.store_ver)
