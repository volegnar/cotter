		if self.keyboard_chars >= 0 and self.outbox ~= nil and self.keyboard_open == true then
			for i = 1, 40 do
				local node = gui.get_node("letter" .. i)
				if gui.pick_node(node, action.x, action.y) and action.pressed then
					if self.outbox == gui.get_node("DevPublicText") then
						if letters[i].output ~= nil and letters[i].output ~= "delete" then
							self.message = self.message .. letters[i].output
							self.keyboard_chars = string.len(self.message)
						elseif letters[i].output == "delete" and self.keyboard_chars > 0 then
							self.message = string.sub(self.message, 1, #self.message - 1)
							self.keyboard_chars = string.len(self.message)
						end
						local devpublic = self.message
						if #devpublic > 28 then
							devpublic = devpublic:sub(1, 28) .. "\n" .. devpublic:sub(29)
						end
						gui.set_text(self.outbox, devpublic)
						self.devpublic = self.message
					elseif self.outbox == gui.get_node("DevTorbulkText") then
						if letters[i].output ~= nil and letters[i].output ~= "delete" then
							self.message = self.message .. letters[i].output
							self.keyboard_chars = string.len(self.message)
						elseif letters[i].output == "delete" and self.keyboard_chars > 0 then
							self.message = string.sub(self.message, 1, #self.message - 1)
							self.keyboard_chars = string.len(self.message)
						end
						local devtorbulk = self.message
						if #devtorbulk > 28 then
							devtorbulk = devtorbulk:sub(1, 28) .. "\n" .. devtorbulk:sub(29)
						end
						gui.set_text(self.outbox, devtorbulk)
						self.devtorbulk = self.message
					end
				end
			end
		end

		if gui.pick_node(gui.get_node("results"), action.x, action.y) and self.keyboard_open == false then
			local node_pos = gui.get_position(gui.get_node("results"))
			if action.pressed then
				last_y = action.y
			end
			if action.released then
				last_y = nil
			end
			if last_y and action.y then
				local dy = action.y - last_y
				last_y = action.y
				node_pos.y = node_pos.y + dy
				local min_y = 380
				local max_y = 3800
				if node_pos.y < min_y then
					node_pos.y = min_y
				elseif node_pos.y > max_y then
					node_pos.y = max_y
				end
				gui.set_position(gui.get_node("results"), node_pos)
			end
		end

		if gui.pick_node(gui.get_node("Back"), action.x, action.y) then
			if action.pressed then
				gui.set_alpha(gui.get_node("Back"), 0.5)
			elseif action.released then
				settings(self)
			end
		end

	end
	end

	if action_id == hash("mouseback") then
		if action.released then
			if texture == "developer" then
				timer.delay(0.05, false, function()
					settings(self)
				end)
			end
			if texture == "interface_list" then
				timer.delay(0.05, false, function()
					settings(self)
				end)
			end
			if texture == "scan" and self.scanning == false then
				lobby(self)
			end
			if texture == "settings" then
				lobby(self)
			end
			if texture == "send" and self.listening == false then
				lobby(self)
			end
		elseif action.pressed then
			if texture == "lobby" then
				if self.support_opened == false then
					if self.exit_opened == true then
						gui.set_enabled(gui.get_node("ExitBg"), false)
						self.exit_opened = false
					elseif self.exit_opened == false then
						gui.set_enabled(gui.get_node("ExitBg"), true)
						self.exit_opened = true
					end
				elseif self.support_opened == true then
					gui.set_enabled(gui.get_node("SupportBg"), false)
					gui.set_enabled(gui.get_node("blur"), false)
					self.support_opened = false
				end
			end
		end
	end

	if action_id == hash("keyback") then
		if action.released then
			if texture == "developer" then
				timer.delay(0.05, false, function()
					settings(self)
				end)
			end
			if texture == "scan" and self.scanning == false then
				lobby(self)
			end
			if texture == "settings" then
				lobby(self)
			end
			if texture == "send" and self.listening == false then
				lobby(self)
			end
		elseif action.pressed then
			if texture == "lobby" then
				if self.support_opened == false then
					if self.exit_opened == true then
						gui.set_enabled(gui.get_node("ExitBg"), false)
						self.exit_opened = false
					elseif self.exit_opened == false then
						gui.set_enabled(gui.get_node("ExitBg"), true)
						self.exit_opened = true
					end
				elseif self.support_opened == true then
					gui.set_enabled(gui.get_node("SupportBg"), false)
					gui.set_enabled(gui.get_node("blur"), false)
					self.support_opened = false
				end
			end
		end
	end
	
	if action_id == hash("wheelup") and not action.pressed and self.scrollable == true then
		local node_pos = gui.get_position(gui.get_node("results"))
		if texture == "scan" or texture == "send" or texture == "developer" then
			node_pos.y = node_pos.y - 20
			if node_pos.y <= 380 then node_pos.y = 380 end
			gui.set_position(gui.get_node("results"), node_pos)
		end
	end
	if action_id == hash("wheeldown") and not action.pressed and self.scrollable == true then
		local node_pos = gui.get_position(gui.get_node("results"))
		if texture == "scan" or texture == "send" or texture == "developer" then
			node_pos.y = node_pos.y + 20
			if node_pos.y >= 3800 then node_pos.y = 3800 end
			gui.set_position(gui.get_node("results"), node_pos)
		end
	end

end