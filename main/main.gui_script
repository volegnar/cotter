local socket = require("socket")

local function check_host(ip, port)
	local tcp = socket.tcp()
	tcp:settimeout(0.1)

	local result, err = tcp:connect(ip, port)
	tcp:close()
	if result then
		return true
	else
		return false, err
	end
end

local function find_color(self, item_name)
	for category_name, category in pairs(interfaces) do
		for _, item in ipairs(category.items) do
			if item == item_name then
				return category
			end
		end
	end
	return nil
end

local function refresh_interfaces(self)
	local interface_nodes = {
		gui.get_node("interface1"),
		gui.get_node("interface2"),
		gui.get_node("interface3"),
		gui.get_node("interface4"),
		gui.get_node("interface5"),
		gui.get_node("interface6"),
		gui.get_node("interface7"),
		gui.get_node("interface8"),
	}
	local Interface_nodes = {
		gui.get_node("Interface1"),
		gui.get_node("Interface2"),
		gui.get_node("Interface3"),
		gui.get_node("Interface4"),
		gui.get_node("Interface5"),
		gui.get_node("Interface6"),
		gui.get_node("Interface7"),
		gui.get_node("Interface8"),
	}
	local address_nodes = {
		gui.get_node("local1"),
		gui.get_node("local2"),
		gui.get_node("local3"),
		gui.get_node("local4"),
		gui.get_node("local5"),
		gui.get_node("local6"),
		gui.get_node("local7"),
		gui.get_node("local8"),
	}
	local Address_nodes = {
		gui.get_node("Local1"),
		gui.get_node("Local2"),
		gui.get_node("Local3"),
		gui.get_node("Local4"),
		gui.get_node("Local5"),
		gui.get_node("Local6"),
		gui.get_node("Local7"),
		gui.get_node("Local8"),
	}
	local bg_nodes = {
		gui.get_node("InterBg1"),
		gui.get_node("InterBg2"),
		gui.get_node("InterBg3"),
		gui.get_node("InterBg4"),
		gui.get_node("InterBg5"),
		gui.get_node("InterBg6"),
		gui.get_node("InterBg7"),
		gui.get_node("InterBg8"),
	}
	local mac_nodes = {
		gui.get_node("mac1"),
		gui.get_node("mac2"),
		gui.get_node("mac3"),
		gui.get_node("mac4"),
		gui.get_node("mac5"),
		gui.get_node("mac6"),
		gui.get_node("mac7"),
		gui.get_node("mac8"),
	}
	local Mac_nodes = {
		gui.get_node("Mac1"),
		gui.get_node("Mac2"),
		gui.get_node("Mac3"),
		gui.get_node("Mac4"),
		gui.get_node("Mac5"),
		gui.get_node("Mac6"),
		gui.get_node("Mac7"),
		gui.get_node("Mac8"),
	}
	valid = {}
	local ifaddrs = sys.get_ifaddrs()
	for _, iface in ipairs(ifaddrs) do
		if iface.name and iface.address then
			table.insert(valid, {
				name = iface.name,
				address = iface.address,
				mac = iface.mac
			})
		end
	end
	for i = 1, #interface_nodes do
		local iface = valid[i]
		local text_node = interface_nodes[i]
		local Text_node = Interface_nodes[i]
		local address_node = address_nodes[i]
		local Address_node = Address_nodes[i]
		local bg_node = bg_nodes[i]
		local mac_node = mac_nodes[i]
		local Mac_node = Mac_nodes[i]
		if iface then
			if texture == "lobby" then
				gui.set_enabled(bg_node, true)
			end
			if self.showmac == false then
				gui.set_position(address_node, vmath.vector3(23, -26, 0))
				gui.set_position(Address_node, vmath.vector3(-100, -26, 0))
				gui.set_position(text_node, vmath.vector3(23, 26, 0))
				gui.set_position(Text_node, vmath.vector3(-100, 26, 0))
				gui.play_flipbook(bg_node, "DoubleBox")
				gui.set_enabled(mac_node, false)
				gui.set_enabled(Mac_node, false)
				if i == 1 then
					gui.set_position(bg_node, vmath.vector3(92.5, 420, 0))
				elseif i == 2 then
					gui.set_position(bg_node, vmath.vector3(267.5, 420, 0))
				elseif i == 3 then
					gui.set_position(bg_node, vmath.vector3(92.5, 340, 0))
				elseif i == 4 then
					gui.set_position(bg_node, vmath.vector3(267.5, 340, 0))
				elseif i == 5 then
					gui.set_position(bg_node, vmath.vector3(92.5, 260, 0))
				elseif i == 6 then
					gui.set_position(bg_node, vmath.vector3(267.5, 260, 0))
				elseif i == 7 then
					gui.set_position(bg_node, vmath.vector3(92.5, 180, 0))
				elseif i == 8 then
					gui.set_position(bg_node, vmath.vector3(267.5, 180, 0))
				end	
			elseif self.showmac == true then
				gui.set_position(address_node, vmath.vector3(23, -5, 0))
				gui.set_position(Address_node, vmath.vector3(-100, -5, 0))
				gui.set_position(text_node, vmath.vector3(23, 47, 0))
				gui.set_position(Text_node, vmath.vector3(-100, 47, 0))
				gui.play_flipbook(bg_node, "TripleBox")
				gui.set_enabled(mac_node, true)
				gui.set_enabled(Mac_node, true)
				if i == 1 then
					gui.set_position(bg_node, vmath.vector3(92.5, 410, 0))
				elseif i == 2 then
					gui.set_position(bg_node, vmath.vector3(267.5, 410, 0))
				elseif i == 3 then
					gui.set_position(bg_node, vmath.vector3(92.5, 300, 0))
				elseif i == 4 then
					gui.set_position(bg_node, vmath.vector3(267.5, 300, 0))
				elseif i == 5 then
					gui.set_position(bg_node, vmath.vector3(92.5, 190, 0))
				elseif i == 6 then
					gui.set_position(bg_node, vmath.vector3(267.5, 190, 0))
				elseif i == 7 then
					gui.set_position(bg_node, vmath.vector3(92.5, 80, 0))
				elseif i == 8 then
					gui.set_position(bg_node, vmath.vector3(267.5, 80, 0))
				end
			end
			local category = find_color(self, iface.name)
			if category then
				color = category.color
			else
				color = vmath.vector4(0.96, 0.86, 0.70, 1)
			end
			gui.set_color(bg_node, color)
			gui.set_text(text_node, iface.name)
			gui.set_text(address_node, iface.address)
			gui.set_text(mac_node, iface.mac)
		else
			gui.set_enabled(bg_node, false)
			gui.set_text(text_node, "")
			gui.set_text(address_node, "")
		end
	end
	if #valid == 0 then
		self.openable = false
		if texture == "lobby" then
			gui.set_enabled(gui.get_node("intertext"), true)
		end
	else 
		self.openable = true
		gui.set_enabled(gui.get_node("intertext"), false)
	end
end

